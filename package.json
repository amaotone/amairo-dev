{
	"name": "amairo-dev",
	"version": "0.0.0",
	"private": true,
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"build": "turbo run build",
		"check": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --colors=off",
		"dev": "turbo run dev --parallel",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/react": "18.3.28",
		"eslint": "9.39.4",
		"eslint-config-next": "15.5.12",
		"prettier": "^3.3.3",
		"turbo": "^2.2.3",
		"typescript": "5.9.3"
	},
	"engines": {
		"bun": ">=1.3.5",
		"node": ">=v20.11.0"
	},
	"resolutions": {
		"@types/react": "18.3.28"
	},
	"packageManager": "bun@1.3.5",
	"lint-staged": {
		"apps/**/*.{js,ts,jsx,tsx}": ["eslint --fix"],
		"packages/**/*.{js,ts,jsx,tsx}": ["eslint --fix"],
		"*.{json,md,html}": ["prettier --write"]
	},
	"dependencies": {
		"lefthook": "^1.8.2"
	}
}
