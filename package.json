{
  "name": "amairo-dev",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/react": "18.3.11",
    "eslint-config-custom": "*",
    "husky": "8.0.3",
    "lint-staged": "13.3.0",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "4.9.5"
  },
  "engines": {
    "npm": ">=8.19.4",
    "node": ">=18.20.4"
  },
  "resolutions": {
    "@types/react": "18.3.11"
  },
  "packageManager": "pnpm@8.15.9",
  "lint-staged": {
    "apps/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ],
    "packages/ui/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/dom-to-image": "2.6.7",
    "dom-to-image": "2.6.0",
    "next": "12.3.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
